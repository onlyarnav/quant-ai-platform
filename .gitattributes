# Auto detect text files
* text=auto

# Force LF for all code files
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.env text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Binary files — never convert
*.parquet binary
*.pkl binary
*.joblib binary
*.png binary
*.jpg binary
*.jpeg binary