# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quantdb
MLFLOW_DB_URL=postgresql://postgres:postgres@postgres:5432/mlflowdb

# External API Keys
ALPHA_VANTAGE_KEY=
FRED_API_KEY=
NEWS_API_KEY=

# Data Settings
DATA_START_DATE=2015-01-01
DATA_UPDATE_MODE=incremental
DATA_REFRESH_INTERVAL_HOURS=24

# Market Universe
MARKET=NSE
STOCK_UNIVERSE=NIFTY500

# ML Settings
MODEL_LOOKBACK_WINDOW=252
MODEL_PREDICTION_HORIZON=1
MODEL_RETRAIN_INTERVAL_DAYS=7

# Backtesting
TRANSACTION_COST=0.001
SLIPPAGE=0.0005

# Portfolio
PORTFOLIO_RISK_FREE_RATE=0.07
MAX_POSITION_SIZE=0.05

# Pipeline Automation
PIPELINE_RUN_TIME=18:30
PIPELINE_TIMEZONE=Asia/Kolkata

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/pipeline.log